{
  "brand": "learngermanwithjonas",
  "style": "brutalist-cartoon",
  "colors": {
    "creme":  "#FBF5F2",
    "black":  "#1A1A1A",
    "orange": "#FF881A",
    "white":  "#FFFFFF"
  },
  "typography": {
    "fontFamily": "Rubik, system-ui, sans-serif",
    "weights": { "regular": 400, "medium": 500, "bold": 700, "black": 800 }
  },
  "border": { "width": "3px", "color": "#1A1A1A", "style": "solid" },
  "radius": { "sm": "8px", "md": "14px", "lg": "22px", "pill": "999px" },
  "shadow": {
    "sm": "4px 4px 0 0 #1A1A1A",
    "md": "6px 6px 0 0 #1A1A1A",
    "lg": "8px 8px 0 0 #1A1A1A",
    "note": "Hard offset shadows only — never soft/blurred."
  },
  "spacing": {
    "1": "4px", "2": "8px", "3": "16px", "4": "24px",
    "5": "40px", "6": "64px", "7": "96px"
  }
}
